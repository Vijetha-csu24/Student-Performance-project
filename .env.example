# Copy to .env and fill in. .env is git-ignored.

# Alpha Vantage (https://www.alphavantage.co/support/#api-key) -- free tier: 25 req/day
ALPHA_VANTAGE_API_KEY=

# FRED (https://fred.stlouisfed.org/docs/api/api_key.html) -- free
FRED_API_KEY=

# Optional fallbacks (not required for initial news ingest)
FINNHUB_API_KEY=
NEWSAPI_KEY=
